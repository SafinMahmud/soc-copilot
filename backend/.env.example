AI_PROVIDER=ollama

# Ollama (host form preferred for production / Cloud Run)
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_SCHEME=http
OLLAMA_MODEL=hf.co/mradermacher/Foundation-Sec-8B-Instruct-GGUF:Q4_K_M
OLLAMA_READY_TIMEOUT=360
# Optional: full URL override (used only if OLLAMA_HOST is unset)
# OLLAMA_BASE_URL=http://localhost:11434

# On-demand GCE VM lifecycle (keeps LLM VM stopped when idle)
GCE_LLM_ENABLED=false
GCE_LLM_PROJECT=
GCE_LLM_ZONE=us-central1-a
GCE_LLM_INSTANCE=ollama-llm
GCE_LLM_IDLE_MINUTES=15
INTERNAL_API_KEY=

# Hugging Face serverless (alternative to Ollama)
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_TOKEN=
HF_MODEL=fdtn-ai/Foundation-Sec-1.1-8B-Instruct:featherless-ai
# Optional: override fallback serverless endpoint
# HF_FALLBACK_API_URL=https://api-inference.huggingface.co/models/fdtn-ai/Foundation-Sec-1.1-8B-Instruct

# Splunk
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USER=
SPLUNK_PASSWORD=
SPLUNK_INDEX=botsv3

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000
